#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const { execSync, spawn } = require('child_process');

const cwd = process.cwd();
const entries = fs.readdirSync(cwd);

const hasGradle = entries.some(e => /\.gradle/.test(e));
const hasXcode = entries.some(e => /\.xcodeproj$/.test(e));

let cmd;
if (hasGradle) {
  cmd = 'studio .';
} else if (hasXcode) {
  cmd = 'xed .';
} else {
  cmd = 'code .';
}

try {
  const child = spawn(cmd, { shell: true, detached: true, stdio: 'ignore' });
  child.unref();
} catch (err) {
  // Fallback to execSync if spawn fails for any reason
  execSync(cmd, { stdio: 'inherit' });
}
