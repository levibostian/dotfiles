{
  "$schema": "https://opencode.ai/config.json",
  "provider": {},
  "theme": "dracula",
  "model": "github-copilot/claude-sonnet-4.6",
  "small_model": "github-copilot/gpt-5-mini",
  "agent": {
    "general": { "model": "github-copilot/gpt-5-mini" },
    "compaction": { "model": "github-copilot/gpt-5-mini" },
    "explore": { "model": "github-copilot/gpt-5-mini" },
    "title": { "model": "github-copilot/gpt-5-mini" },
    "summary": { "model": "github-copilot/gpt-5-mini" }
  },
  "mcp": {
    "serena": {
      "type": "local",
      // Or ["bun", "x", "my-mcp-command"]
      "command": ["uvx", "--from", "git+https://github.com/oraios/serena", "serena", "start-mcp-server", "--context", "ide", "--project", "$(pwd)", "--enable-web-dashboard", "False"],
      "enabled": true,
      "environment": {},
    },
  },
  // disable auto compaction to save on github premium requests. I can always manually trigger it when I want to.
  "compaction": {
    "auto": false,
    "prune": true
  },
  "keybinds": {
    "app_exit": "ctrl+d,<leader>q", // simply removing ctrl+c as an exit keybind
    "session_child_cycle": "<leader>l,<leader>right", // default is `<leader>right`, but on my ergodox it's inconvenient
    "session_list": "none", // disable because default conflicts with session_child_cycle
    "session_child_cycle_reverse": "<leader>j,<leader>left", // default is `<leader>left`, but on my ergodox it's inconvenient
  },
  "plugin": [
    "@mohak34/opencode-notifier@0.1.30"
  ],
  "permission": {
    "external_directory": {
      "/tmp/**": "allow",
      "/private/tmp/**": "allow",       
    }
  },
  "lsp": {
    // because I use swift for xcode/ios apps, this LSP just doesn't really work. 
    "sourcekit-lsp": {
      "disabled": true
    }
  }
}
